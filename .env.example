# ======================
# DATABASE (PostgreSQL)
# ======================

POSTGRES_USER=triage_user
POSTGRES_PASSWORD=change-me
POSTGRES_DB=triage_db

DB_HOST=db
DB_PORT=5432

DATABASE_URL=postgresql://triage_user:change-me@db:5432/triage_db

# URL utilisée depuis l'hôte (hors Docker), ex: scripts ml/* via uv run
ML_DATABASE_URL=postgresql://triage_user:change-me@localhost:5432/triage_db


# ======================
# API SECURITY
# ======================
API_KEY=change-me

# ======================
# RGPD - PSEUDONYMISATION
# ======================
# Sel secret utilisé pour hacher (HMAC-SHA256) les patient_id avant stockage.
# Ne jamais committer ni partager cette valeur.
PATIENT_ID_SALT=change-me

# ======================
# DEPLOIEMENT (docker-compose.prod.yml)
# ======================
# DOCKERHUB_USERNAME=brunobiscay
# IMAGE_TAG=latest
